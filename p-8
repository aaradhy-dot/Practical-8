* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}
body {
    font-family: Arial, sans-serif;
    background: linear-gradient(to right, #0f2027, #203a43, #2c5364);
}
header {
    background: black;
    width: 100%;
    padding: 12px;
    text-align: center;
}
header h1 {
    color: #00e6e6;
    font-size: 22px;
}
.gallery {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 8px;
    padding: 10px;
}
.card {
    position: relative;
    overflow: hidden;
    border-radius: 8px;
}
.card img {
    width: 100%;
    height: 110px;     
    object-fit: cover;
    transition: 0.4s ease;
}
.card:hover img {
    transform: scale(1.1);
    filter: brightness(65%);
}
.card span {
    position: absolute;
    bottom: 0;
    width: 100%;
    color: white;
    font-size: 11px;
    padding: 5px;
    background: rgba(0,0,0,0.7);
    transform: translateY(100%);
    transition: 0.4s;
}
.card:hover span {
    transform: translateY(0);
}
hr {
    width: 95%;
    margin: 6px auto;
}
.footer {
    text-align: center;
    color: white;
    font-size: 12px;
    margin: 6px;
}
